rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: rsvps
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-100 chars)
    //   - guests: number (required, 1-10)
    //   - guestNames: list (required)
    //   - attendance: string (required, 'yes' or 'no')
    //   - message: string (optional, 0-1000 chars)
    //   - song: string (optional, 0-200 chars)
    //   - hasIntolerances: string (required, 'yes' or 'no')
    //   - intolerancesDetails: string (optional, 0-500 chars)
    //   - adminNotes: string (optional, 0-1000 chars)
    //   - created_at: string (required, ISO 8601 format)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "michelebattaglia.ing@gmail.com"));
    }

    function isValidRSVP(data) {
      return data.keys().hasAll(['name', 'guests', 'guestNames', 'attendance', 'hasIntolerances', 'created_at']) &&
             data.keys().hasOnly(['name', 'guests', 'guestNames', 'attendance', 'message', 'song', 'hasIntolerances', 'intolerancesDetails', 'adminNotes', 'created_at']) &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.guests is int && data.guests >= 1 && data.guests <= 10 &&
             data.guestNames is list && data.guestNames.size() == data.guests &&
             data.attendance in ['yes', 'no'] &&
             data.hasIntolerances in ['yes', 'no'] &&
             (!('message' in data) || (data.message is string && data.message.size() <= 1000)) &&
             (!('song' in data) || (data.song is string && data.song.size() <= 200)) &&
             (!('intolerancesDetails' in data) || (data.intolerancesDetails is string && data.intolerancesDetails.size() <= 500)) &&
             (!('adminNotes' in data) || (data.adminNotes is string && data.adminNotes.size() <= 1000)) &&
             (data.hasIntolerances == 'no' || ('intolerancesDetails' in data && data.intolerancesDetails.size() > 0)) &&
             data.created_at is string; // Simplified date check for now
    }

    match /rsvps/{rsvpId} {
      // Anyone can submit an RSVP
      allow create: if isValidRSVP(request.resource.data);
      
      // Only admin can read, update, or delete RSVPs
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
